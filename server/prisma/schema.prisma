generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum TrackId {
  cybersecurity
  networks
  devops
  sysadmin
}

enum Level {
  Junior
  Middle
  Senior
}

model User {
  id              String         @id @default(uuid())
  username        String         @unique
  firstName       String?
  lastName        String?
  displayName     String?
  email           String?
  phoneNumber     String?
  telegramContact String?
  telegramChatId  String?        @unique
  telegramUsername String?
  telegramLinkedAt DateTime?
  role            Role           @default(USER)
  lastLoginAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdEvents   Event[]        @relation("EventCreatedBy")
  createdArchives ArchiveEntry[] @relation("ArchiveCreatedBy")
  registrations   EventRegistration[]
  telegramLinkTokens TelegramLinkToken[]
}

model Event {
  id           String        @id @default(uuid())
  track        TrackId
  level        Level
  title        String
  duration     String
  location     String
  description  String
  registrationLink String?
  startsAt     DateTime
  createdById  String?
  createdBy    User?         @relation("EventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  archiveEntry ArchiveEntry?
  registrations EventRegistration[]
  guestTelegramTokens TelegramGuestRegistrationToken[]

  @@index([startsAt])
  @@index([track, level])
}

enum RegistrationContactType {
  TELEGRAM
  WHATSAPP
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model EventRegistration {
  id                   String                     @id @default(uuid())
  eventId              String
  userId               String?
  contactType          RegistrationContactType
  contactValue         String
  guestFullName        String?
  guestPhone           String?
  guestTelegramTag     String?
  notificationStatus   NotificationDeliveryStatus @default(PENDING)
  notificationProvider String?
  providerMessageId    String?
  notificationError    String?
  notifiedAt           DateTime?
  reminderStatus       NotificationDeliveryStatus @default(PENDING)
  reminderProvider     String?
  reminderMessageId    String?
  reminderError        String?
  reminderSentAt       DateTime?
  createdAt            DateTime                   @default(now())
  event                Event                      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user                 User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventId, createdAt])
  @@index([userId, createdAt])
  @@index([reminderStatus, reminderSentAt])
  @@unique([eventId, userId])
  @@unique([eventId, contactType, contactValue])
}

model TelegramLinkToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model TelegramGuestRegistrationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  eventId   String
  chatId    String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([chatId, expiresAt, usedAt])
  @@index([eventId, createdAt])
}

model ArchiveEntry {
  id          String   @id @default(uuid())
  eventId     String   @unique
  summary     String
  materials   String
  publishedAt DateTime
  createdById String?
  createdBy   User?    @relation("ArchiveCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([publishedAt])
}
