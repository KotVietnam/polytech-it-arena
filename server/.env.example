NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
DATABASE_URL=file:./dev.db
JWT_SECRET=dev-super-secret-change-me-123456
JWT_EXPIRES_IN=8h

# ad | mock | keycloak
AUTH_MODE=mock

# Active Directory settings (required when AUTH_MODE=ad)
AD_URL=ldap://ad.example.local:389
AD_BASE_DN=DC=example,DC=local
AD_BIND_DN=CN=svc-ldap,OU=Service,DC=example,DC=local
AD_BIND_PASSWORD=replace-me
AD_USER_FILTER=(sAMAccountName={{username}})
AD_ADMIN_GROUP_DN=CN=CyberClubAdmins,OU=Groups,DC=example,DC=local
AD_SKIP_TLS_VERIFY=false

# Mock auth settings (for local development)
MOCK_ADMIN_USERNAME=admin
MOCK_ADMIN_PASSWORD=admin123
MOCK_USER_PASSWORD=user123

# Keycloak settings (required when AUTH_MODE=keycloak)
# Optional explicit issuer. Format: https://keycloak.example.com/realms/your-realm
KEYCLOAK_ISSUER_URL=
# Optional base URL + realm. Backend will try:
# 1) <base>/realms/<realm>
# 2) <base>/auth/realms/<realm>
KEYCLOAK_BASE_URL=
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
# Realm/client role name that should be treated as ADMIN
KEYCLOAK_ADMIN_ROLE=Administrators

# Public frontend URL used in notification text links
APP_PUBLIC_URL=https://itarena.kotvietnam.kz

# Telegram bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_API_URL=https://api.telegram.org
# Optional, if empty backend resolves username via getMe
TELEGRAM_BOT_USERNAME=
# Comma-separated list of admin chat ids/usernames for guest registration alerts
TELEGRAM_ADMIN_CHAT_IDS=

# WhatsApp Cloud API (optional)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v22.0

# Polling interval for reminders (default 5 min)
EVENT_REMINDER_INTERVAL_MS=300000
